# このファイルを .env.local にコピーして使う(.env* は .gitignore 済み)。
#   cp .env.example .env.local

# ローカル DB(docker compose up -d で起動)への接続
DATABASE_URL=postgres://postgres:postgres@localhost:55432/washokumap

# 予約通知(メール)。3つすべて設定すると Resend で送信、未設定ならログ出力にフォールバック。
# RESEND_API_KEY=re_xxxxxxxx
# NOTIFICATION_FROM_EMAIL=reservations@your-domain.com
# RESERVATION_DESK_EMAIL=desk@your-domain.com
