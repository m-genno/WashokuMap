# このファイルを .env.local にコピーして使う(.env* は .gitignore 済み)。
#   cp .env.example .env.local

# ローカル DB(docker compose up -d で起動)への接続
DATABASE_URL=postgres://postgres:postgres@localhost:55432/washokumap

# 予約通知(メール)。3つすべて設定すると Resend で送信、未設定ならログ出力にフォールバック。
# 店舗デスク宛(新規リクエスト)に加え、お客様宛(確定/お断り/代替提案/キャンセル)も
# RESEND_API_KEY と NOTIFICATION_FROM_EMAIL があれば送信する。
# RESEND_API_KEY=re_xxxxxxxx
# NOTIFICATION_FROM_EMAIL=reservations@your-domain.com
# RESERVATION_DESK_EMAIL=desk@your-domain.com

# 公開URL(本番のオリジン)。設定するとお客様宛メールに予約状況ページ
# (代替案の承諾/お断りができる)へのリンクを載せる。未設定なら省略。
# APP_BASE_URL=https://washokumap.example.com

# 翻訳(DeepL)。未設定なら要望の日本語訳は付かない(原文のみ店舗へ伝達)。
# 無料キーは末尾が ":fx"。DEEPL_API_URL は省略可(プロキシ/テスト用の上書き)。
# DEEPL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx
# DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# 管理(店舗投入)API の簡易保護。設定すると x-admin-token ヘッダ必須。本番では必ず設定。
# ADMIN_TOKEN=change-me

# ジオコーディング(住所→緯度経度)。既定はキーレスの Nominatim(OSM)。
# GEOCODE_API_URL=https://nominatim.openstreetmap.org/search
